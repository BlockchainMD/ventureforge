# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...  # Optional

# Research
TAVILY_API_KEY=tvly-...
CRUNCHBASE_API_KEY=  # Optional

# Database
DATABASE_URL=sqlite:///./ventureforge.db

# Orchestration
DEFAULT_MAX_ROUNDS=4
DEFAULT_QUALITY_THRESHOLD=0.82
MAX_CONCURRENT_RESEARCH_THREADS=5
RESEARCH_CACHE_TTL_HOURS=24

# LLM Settings
DEEP_REASONING_MODEL=claude-opus-4-6
FAST_MODEL=claude-sonnet-4-6
MAX_TOKENS_DEFAULT=4096
TEMPERATURE_DEFAULT=0.7

# Output
OUTPUT_DIR=./outputs
